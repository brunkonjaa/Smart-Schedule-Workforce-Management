{
  "name": "smart-schedule-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend service for the Smart Schedule project.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "node src/scripts/run-migrations.js up",
    "db:migrate:status": "node src/scripts/run-migrations.js status",
    "db:seed:demo-history": "node src/scripts/seed-demo-history.js",
    "db:seed:demo-history:reset": "node src/scripts/seed-demo-history.js --reset",
    "db:seed:staff-history": "node src/scripts/seed-staff-history.js",
    "local:evidence:check": "node src/scripts/prepare-local-evidence.js check",
    "local:evidence:migrate": "node src/scripts/prepare-local-evidence.js migrate",
    "local:evidence:seed": "node src/scripts/prepare-local-evidence.js seed-rota",
    "local:evidence:all": "node src/scripts/prepare-local-evidence.js all",
    "local:evidence:start": "node -r dotenv/config src/server.js dotenv_config_path=local-evidence.env",
    "local:chat:reset": "node src/scripts/reset-local-chat.js",
    "local:audit:reset": "node src/scripts/reset-local-audit.js",
    "local:audit:size": "node src/scripts/measure-local-audit-storage.js",
    "local:identity:audit": "node src/scripts/audit-local-demo-identities.js",
    "qa:admin-browser": "node src/scripts/run-admin-browser-checks.js",
    "security:benchmark": "node src/scripts/benchmark-password-hashing.js",
    "security:repo-review": "node src/scripts/review-repository-security.js",
    "lint": "eslint . ../frontend/src ../frontend/public/service-worker.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage --coverageReporters=text --coverageReporters=text-summary --coverageReporters=lcov",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@simplewebauthn/server": "^13.3.2",
    "argon2": "^0.45.0",
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.1",
    "helmet": "^8.2.0",
    "pg": "^8.13.1",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "eslint": "^9.39.5",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "playwright": "^1.61.1",
    "supertest": "^7.0.0"
  }
}
