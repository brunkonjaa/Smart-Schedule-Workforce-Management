{
  "name": "smart-schedule-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend service for the Smart Schedule project.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "node src/scripts/run-migrations.js up",
    "db:migrate:status": "node src/scripts/run-migrations.js status",
    "db:seed:demo-history": "node src/scripts/seed-demo-history.js",
    "db:seed:demo-history:reset": "node src/scripts/seed-demo-history.js --reset",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.1",
    "helmet": "^8.2.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0"
  }
}
